# ============================================================
# Personal Site - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control!
# ============================================================

# ------------------------------------------------------------
# Database (Neon PostgreSQL)
# Get yours at: https://neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.pooler.us-east-1.aws.neon.tech/dbname?sslmode=require"

# ------------------------------------------------------------
# Authentication
# Generate a secret: openssl rand -base64 32
# ------------------------------------------------------------
NEXTAUTH_SECRET="your_random_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# Admin Account
# Used by seed script to create the admin user
# ------------------------------------------------------------
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="your_admin_password"

# ------------------------------------------------------------
# GitHub Integration (Optional)
# Generate a token at: https://github.com/settings/tokens
# Needed for: GitHub activity sync in Playground
# ------------------------------------------------------------
GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"
GITHUB_USERNAME="your_github_username"

# ------------------------------------------------------------
# Competitive Programming Profiles (Optional)
# Used for: Playground stats page
# ------------------------------------------------------------
LEETCODE_USERNAME="your_leetcode_username"
CODEFORCES_USERNAME="your_codeforces_username"
